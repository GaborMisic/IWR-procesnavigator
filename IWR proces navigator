<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IWR Procesnavigator</title>
<style>
  :root {
    --blauw: #1F3864;
    --lichtblauw: #2E74B5;
    --rood: #C00000;
    --groen: #375623;
    --geel: #B8860B;
    --geellight: #FFFBEA;
    --oranje: #C55A11;
    --grijs: #F7F8FA;
    --border: #E2E6EF;
    --tekst: #1a1a2e;
    --subtekst: #666;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; background: #F0F3F8; color: var(--tekst); }
  .header { background: var(--blauw); color: white; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 8px rgba(0,0,0,0.15); }
  .header-left h1 { font-size: 18px; font-weight: 700; letter-spacing: 0.3px; }
  .header-left p { font-size: 11px; opacity: 0.65; margin-top: 2px; }
  .header-right { font-size: 11px; opacity: 0.75; text-align: right; }
  .container { max-width: 1280px; margin: 0 auto; padding: 24px 20px; }
  .card { background: white; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.07); margin-bottom: 18px; border: 1px solid var(--border); overflow: hidden; }
  .card-header { background: var(--blauw); color: white; padding: 9px 18px; font-weight: 600; font-size: 12px; letter-spacing: 0.4px; display: flex; align-items: center; justify-content: space-between; }
  .card-body { padding: 16px 18px; }
  .invoer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
  .invoer-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr) 1.2fr; gap: 14px; }
  @media(max-width: 720px) { .invoer-grid, .invoer-grid-2 { grid-template-columns: 1fr; } }
  .field label { display: block; font-size: 11px; font-weight: 600; color: var(--subtekst); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.4px; }
  .field input[type=text], .field input[type=date], .field select { width: 100%; padding: 8px 10px; border: 1.5px solid var(--border); border-radius: 6px; font-size: 13px; color: var(--tekst); background: white; outline: none; transition: border-color 0.15s; font-family: inherit; }
  .field input:focus, .field select:focus { border-color: var(--lichtblauw); }
  .vgrid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  @media(max-width:700px){ .vgrid { grid-template-columns: 1fr; } }
  .vrow { display: flex; align-items: center; gap: 8px; background: var(--grijs); border-radius: 6px; padding: 7px 10px; border: 1px solid var(--border); }
  .vrow label { flex: 1; font-size: 11px; color: #555; line-height: 1.3; }
  .vrow input[type=number] { width: 58px; padding: 5px 6px; border: 1.5px solid var(--border); border-radius: 5px; font-size: 13px; text-align: center; outline: none; font-family: inherit; }
  .vrow input:focus { border-color: var(--lichtblauw); }
  .vrow .eenheid { font-size: 10px; color: #999; white-space: nowrap; }
  .impact-balk { margin-top: 12px; padding: 9px 14px; border-radius: 7px; font-weight: 600; font-size: 12px; display: flex; align-items: center; gap: 8px; }
  .impact-ok  { background: #EAF4E7; color: #2E6B20; border: 1px solid #B8DFB0; }
  .impact-warn{ background: #FEF3F0; color: #9B2300; border: 1px solid #F5C4B8; }
  .toggle-btn { background: none; border: none; cursor: pointer; color: white; font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 6px; }
  .arr { display: inline-block; transition: transform 0.2s; font-size: 10px; }
  .legende { display: flex; gap: 16px; flex-wrap: wrap; padding: 8px 14px; background: #FAFBFD; border-bottom: 1px solid var(--border); font-size: 11px; color: #666; }
  .tbl-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  thead th { background: #EEF1F8; color: #333; padding: 8px 10px; text-align: left; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.4px; border-bottom: 2px solid var(--border); white-space: nowrap; }
  tbody tr { border-bottom: 1px solid #F0F2F7; }
  tbody tr:hover { background: #F5F7FB; }
  tbody td { padding: 9px 10px; vertical-align: middle; }
  .gsu-row td { background: #FFFBEA !important; border-top: 2px solid #E8C840; border-bottom: 2px solid #E8C840; }
  .gsu-row:hover td { background: #FFF8DC !important; }
  .fase-badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 10px; font-weight: 600; white-space: nowrap; letter-spacing: 0.2px; }
  .fase-init { background: #EAF4E7; color: #2E6B20; }
  .fase-eng  { background: #EEF1F8; color: #2E4B8A; }
  .fase-wvb  { background: #FEF6EE; color: #A0400A; }
  .fase-uit  { background: #FFFBEA; color: #7A5900; }
  .tag-badge { display: inline-block; padding: 1px 6px; border-radius: 10px; font-size: 9px; font-weight: 700; letter-spacing: 0.3px; margin-left: 5px; vertical-align: middle; }
  .tag-ss   { background: #FEE8E4; color: #9B2300; }
  .tag-gate { background: #EAF4E7; color: #2E6B20; }
  .tag-mijl { background: #EEF1F8; color: #2E4B8A; }
  .tag-gsu  { background: #FFFBEA; color: #7A5900; }
  .mijl-titel { font-weight: 600; font-size: 12px; color: var(--tekst); line-height: 1.4; }
  .mijl-sub   { font-size: 10px; color: #888; margin-top: 2px; line-height: 1.3; }
  .sl-cel { text-align: center; }
  .sl-icon { font-size: 16px; display: block; }
  .datum-cel { font-weight: 600; font-size: 12px; white-space: nowrap; }
  .d-groen  { color: #2E6B20; }
  .d-oranje { color: #C55A11; }
  .d-rood   { color: #9B2300; }
  .d-nvt    { color: #bbb; font-style: italic; font-weight: normal; }
  .d-leeg   { color: #bbb; font-style: italic; font-weight: normal; font-size: 11px; }
  .wk-cel { font-size: 11px; color: #999; text-align: center; }
  .wk-extra-pos { color: #9B2300; font-weight: 700; }
  .status-sel { padding: 4px 6px; border: 1.5px solid var(--border); border-radius: 5px; font-size: 11px; background: white; width: 130px; font-family: inherit; color: var(--tekst); cursor: pointer; outline: none; }
  .status-sel:focus { border-color: var(--lichtblauw); }
  .toel { font-size: 10px; color: #999; line-height: 1.4; max-width: 200px; }
  .wie-cel { font-size: 11px; color: #666; max-width: 160px; line-height: 1.3; }
  .footer { text-align: center; color: #bbb; font-size: 11px; padding: 24px; }
  .nr-cel { font-weight: 700; color: var(--blauw); text-align: center; font-size: 13px; }
  .nr-gsu { color: #7A5900; }
  .divider-row td { background: #F0F3F8 !important; padding: 4px 10px; font-size: 10px; font-weight: 700; color: #888; text-transform: uppercase; letter-spacing: 0.5px; border-top: 1px solid var(--border); }
</style>
</head>
<body>
<div class="header">
  <div class="header-left">
    <h1>IWR Procesnavigator</h1>
    <p>Infrawerk Rijnmond · Kritieke mijlpalen &amp; doorlooptijden</p>
  </div>
  <div class="header-right" id="vandaag-txt"></div>
</div>
<div class="container">
  <div class="card">
    <div class="card-header">Stap 1 — Projectgegevens</div>
    <div class="card-body">
      <div class="invoer-grid">
        <div class="field"><label>Projectnaam</label><input type="text" id="proj-naam" placeholder="bijv. Herinrichting Koningsweg"></div>
        <div class="field"><label>Xaris projectnummer</label><input type="text" id="proj-xaris" placeholder="bijv. 2025-0123"></div>
        <div class="field"><label>Locatie / tracégebied</label><input type="text" id="proj-locatie" placeholder="bijv. Rotterdam-Noord"></div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">Stap 2 &amp; 3 — Route, Ketenvariant en GSU-datum</div>
    <div class="card-body">
      <div class="invoer-grid-2">
        <div class="field">
          <label>Route</label>
          <select id="route" onchange="herbereken()">
            <option value="KG">Klantgedreven Hoofdleidingen</option>
            <option value="NG">Netgedreven</option>
            <option value="RC" selected>Reconstructies</option>
          </select>
        </div>
        <div class="field">
          <label>Ketenvariant</label>
          <select id="variant" onchange="herbereken()">
            <option value="NOidK">NOidK – Niet Opgeschoven in de Keten</option>
            <option value="OidK" selected>OidK – Opgeschoven in de Keten</option>
          </select>
        </div>
        <div class="field">
          <label>GSU-datum (Startuitvoering = week 0)</label>
          <input type="date" id="gsu" onchange="herbereken()">
        </div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">
      <button class="toggle-btn" onclick="toggleV()">
        <span class="arr" id="varr">▼</span>
        Stap 4 — Vertragingen (optioneel)
      </button>
    </div>
    <div id="vbody">
      <div class="card-body">
        <div class="vgrid">
          <div class="vrow"><label>Extra weken bodemonderzoek</label><input type="number" id="v1" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken proefsleuven / bijz. activiteiten</label><input type="number" id="v2" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken tracéonderzoek (OidK)</label><input type="number" id="v3" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken VO beoordeling / iteraties</label><input type="number" id="v4" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken DO + dossier beoordeling</label><input type="number" id="v5" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken vergunningenprocedure</label><input type="number" id="v6" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken begrotingstraject</label><input type="number" id="v7" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken werkmap / kick-off voorbereiding</label><input type="number" id="v8" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
          <div class="vrow"><label>Extra weken eng. opdracht / begroting (OidK)</label><input type="number" id="v9" value="0" min="0" step="0.5" onchange="herbereken()"><span class="eenheid">wkn</span></div>
        </div>
        <div class="impact-balk impact-ok" id="impact-balk">✅ Geen vertraging ingevoerd — planning haalbaar</div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-header">Sleuteldata — kritieke mijlpalen in chronologische volgorde</div>
    <div class="legende">
      <span>🟢 Op tijd (&gt;7 dagen)</span>
      <span>🟠 Actie nodig (≤7 dagen)</span>
      <span>🔴 Verlopen</span>
      <span>✅ Gereed (handmatig)</span>
      <span>⏸ N.v.t. voor deze route/variant</span>
    </div>
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th><th>Fase</th><th>Mijlpaal / Gate</th><th>Wie levert aan</th>
            <th style="text-align:center;">Basis wk</th>
            <th style="text-align:center;">+ extra</th>
            <th style="text-align:center;">Gecorr. wk</th>
            <th style="text-align:center;">Uiterste datum</th>
            <th style="text-align:center;">Status</th>
            <th>Toelichting</th>
          </tr>
        </thead>
        <tbody id="tbl-body"></tbody>
      </table>
    </div>
  </div>
</div>
<div class="footer">IWR Procesnavigator · Infrawerk Rijnmond · <span id="footer-datum"></span></div>
<script>
const M=[
  {nr:1,fase:"Initiatiefase",titel:"Initiatiefase: uiterste startdatum",sub:"KG: >wk -30 | NG: >wk -43 | RC: >wk -35",wie:"Combi Coördinator / Netbeheerder",wk:{KG_NOidK:-30,KG_OidK:-30,NG_NOidK:-43,NG_OidK:-43,RC_NOidK:-35,RC_OidK:-35},tag:"",toel:"Als je hier al achterloopt, schuift alles op."},
  {nr:2,fase:"Initiatiefase",titel:"FO / Projectdossier akkoord NB",sub:"KG: akkoord dossier | NG/RC: FO Stedin + Evides in Xaris",wie:"Netbeheerder → Combi Coördinator | Xaris",wk:{KG_NOidK:-24,KG_OidK:-24,NG_NOidK:-41,NG_OidK:-41,RC_NOidK:-33,RC_OidK:-33},tag:"gate",tagLabel:"Gate Initiatiefase",toel:"Zonder akkoord start de engineeringsfase niet."},
  {nr:3,fase:"Engineeringsfase",titel:"Engineering: uiterste startdatum",sub:"NOidK: NB start tracévoorbereiding | OidK: NB maakt werkmap op",wie:"Netbeheerder",wk:{KG_NOidK:-23,KG_OidK:-23,NG_NOidK:-40,NG_OidK:-40,RC_NOidK:-32,RC_OidK:-32},tag:"",toel:"Startmoment engineering. Te laat starten = domino-effect."},
  {nr:4,fase:"Engineeringsfase",titel:"Warme overdracht + opdracht engineering",sub:"Werkmap compleet → overdracht + kick-off bij Aannemer (alleen OidK)",wie:"Netbeheerder (Stedin + Evides) → Aannemer | Xaris",wk:{KG_NOidK:null,KG_OidK:-23,NG_NOidK:null,NG_OidK:-37,RC_NOidK:null,RC_OidK:-29},tag:"",toel:"Aannemer start pas als BEIDE NB werkmap compleet hebben + inkooporder verstrekt."},
  {nr:5,fase:"Engineeringsfase",titel:"Bodemonderzoek gereed (CROW 400 in Xaris)",sub:"NOidK: NB initieert | OidK: NB op verzoek Aannemer",wie:"Netbeheerder → Xaris",wk:{KG_NOidK:-21,KG_OidK:-21,NG_NOidK:-36,NG_OidK:-35,RC_NOidK:-30,RC_OidK:-25},tag:"ss",tagLabel:"Showstopper",toel:"Vereist vóór proefsleuven. KG=10wd | NG=20wd | RC=10wd."},
  {nr:6,fase:"Engineeringsfase",titel:"Proefsleuven / tracéonderzoek gereed",sub:"NOidK: rapport goedgekeurd door NB | OidK: schouw + CROW500 + proefsleuven gereed",wie:"Aannemer → NB (goedkeuring) | Xaris",wk:{KG_NOidK:-17,KG_OidK:-17,NG_NOidK:-20,NG_OidK:-22,RC_NOidK:-22,RC_OidK:-20},tag:"ss",tagLabel:"Showstopper",toel:"Vereist vóór VO. NOidK: KG=10wd / NG=50wd / RC=20wd. OidK: NG=75wd / RC=35wd."},
  {nr:7,fase:"Engineeringsfase",titel:"Voorlopig Ontwerp (VO) goedgekeurd",sub:"NOidK: intern NB goedgekeurd | OidK: beide NB beoordelen AAN-VO",wie:"Netbeheerder(s) → Xaris",wk:{KG_NOidK:-17,KG_OidK:-17,NG_NOidK:-20,NG_OidK:-18,RC_NOidK:-20,RC_OidK:-18},tag:"ss",tagLabel:"Showstopper",toel:"Vereist vóór DO. OidK: beide NB moeten tegelijkertijd beoordelen."},
  {nr:8,fase:"Engineeringsfase",titel:"Definitief Ontwerp (DO) getekend",sub:"Verplicht: ZOWEL Stedin ALS Evides getekend DO in Xaris",wie:"Netbeheerder(s) → Xaris",wk:{KG_NOidK:-15,KG_OidK:-15,NG_NOidK:-15,NG_OidK:-15,RC_NOidK:-15,RC_OidK:-15},tag:"mijl",tagLabel:"Mijlpaal",toel:"Harde gate: als één NB niet tekent, gaat het proces niet verder."},
  {nr:9,fase:"Engineeringsfase",titel:"DO-dossier goedgekeurd (VGMK-checklist)",sub:"NOidK: Aannemer keurt | OidK: Netbeheerder keurt",wie:"Aannemer / NB → Xaris",wk:{KG_NOidK:-14,KG_OidK:-14,NG_NOidK:-14,NG_OidK:-14,RC_NOidK:-14,RC_OidK:-14},tag:"gate",tagLabel:"Gate Engineering",toel:"Formele afsluiting engineering. Zonder dit dossier start WVB niet."},
  {nr:10,fase:"Werkvoorbereiding",titel:"Begroting geclassificeerd (beide NB akkoord)",sub:"Infradock: maken (20wd) → afstemmen (15wd) → classificeren (5wd)",wie:"Aannemer → Netbeheerder(s) | Infradock",wk:{KG_NOidK:-7,KG_OidK:-7,NG_NOidK:-7,NG_OidK:-7,RC_NOidK:-7,RC_OidK:-7},tag:"mijl",tagLabel:"Mijlpaal",toel:"Vereist voor opdrachtverstrekking uitvoering. Beide NB moeten akkoord zijn."},
  {nr:11,fase:"Werkvoorbereiding",titel:"Vergunningen + ZRO verleend in Xaris",sub:"Zakelijk recht, ligvergunningen, omgevingsvergunningen",wie:"Grondzaken (Stedin) / Vergunningendesk (Evides) → Xaris",wk:{KG_NOidK:-5,KG_OidK:-5,NG_NOidK:-5,NG_OidK:-5,RC_NOidK:-5,RC_OidK:-5},tag:"mijl",tagLabel:"Mijlpaal",toel:"Loopt parallel aan begroting (start wk -14, 40wd). Noodzakelijk voor uitvoering."},
  {nr:12,fase:"Werkvoorbereiding",titel:"Werkmap compleet + kick-off getekend",sub:"Formele opdrachtbevestiging uitvoering | Stedin in de lead",wie:"Netbeheerder → Aannemer | Xaris + fysiek overleg",wk:{KG_NOidK:-5,KG_OidK:-5,NG_NOidK:-5,NG_OidK:-5,RC_NOidK:-5,RC_OidK:-5},tag:"gate",tagLabel:"Gate WVB",toel:"Getekend kick-off formulier = formele opdrachtbevestiging voor uitvoering."},
  {nr:"★",fase:"Uitvoering",titel:"GSU — Startuitvoering = Week 0",sub:"Alle bovenstaande gates moeten gereed zijn",wie:"— referentiepunt",wk:{KG_NOidK:0,KG_OidK:0,NG_NOidK:0,NG_OidK:0,RC_NOidK:0,RC_OidK:0},tag:"gsu",tagLabel:"GSU",toel:"Bij vertraging: GSU moet eerder gepland worden of het project verschuift."}
];
const SO=[{v:"",l:"— selecteer —"},{v:"gereed",l:"✅  Gereed"},{v:"loopt",l:"⏳  Loopt"},{v:"review",l:"🔄  Review"},{v:"geblokkeerd",l:"⛔  Geblokkeerd"},{v:"nog-te-starten",l:"📋  Nog te starten"}];
const staat={};
function fmt(d){if(!d||isNaN(d.getTime()))return null;return d.getDate().toString().padStart(2,"0")+"-"+(d.getMonth()+1).toString().padStart(2,"0")+"-"+d.getFullYear();}
function telDagen(basis,weken){const r=new Date(basis.getTime());r.setDate(r.getDate()+Math.round(weken*7));return r;}
function sl(datum,sv){
  if(sv==="gereed")return{icon:"✅",label:"Gereed",kl:"d-groen"};
  if(!datum)return{icon:"—",label:"",kl:"d-leeg"};
  const v=new Date();v.setHours(0,0,0,0);
  const diff=Math.floor((datum.getTime()-v.getTime())/86400000);
  if(diff<0)return{icon:"🔴",label:Math.abs(diff)+"d verlopen",kl:"d-rood"};
  if(diff<=7)return{icon:"🟠",label:diff+"d resterend",kl:"d-oranje"};
  return{icon:"🟢",label:diff+"d resterend",kl:"d-groen"};
}
function fKl(f){if(f==="Initiatiefase")return"fase-init";if(f==="Engineeringsfase")return"fase-eng";if(f==="Werkvoorbereiding")return"fase-wvb";return"fase-uit";}
function tHtml(m){if(!m.tag)return"";const k={ss:"tag-ss",gate:"tag-gate",mijl:"tag-mijl",gsu:"tag-gsu"}[m.tag]||"";return`<span class="tag-badge ${k}">${m.tagLabel}</span>`;}
function vv(){return{v1:+document.getElementById("v1").value||0,v2:+document.getElementById("v2").value||0,v3:+document.getElementById("v3").value||0,v4:+document.getElementById("v4").value||0,v5:+document.getElementById("v5").value||0,v6:+document.getElementById("v6").value||0,v7:+document.getElementById("v7").value||0,v8:+document.getElementById("v8").value||0,v9:+document.getElementById("v9").value||0};}
function xw(nr,sleutel,v){
  const o=sleutel.endsWith("OidK");
  const pad=o?(v.v9+v.v3):(v.v1+v.v2);
  switch(nr){
    case 1:case 2:case 3:return 0;
    case 4:return o?v.v9:0;
    case 5:return o?v.v9:v.v1;
    case 6:return pad;
    case 7:return pad+v.v4;
    case 8:return pad+v.v4+v.v5;
    case 9:return pad+v.v4+v.v5;
    case 10:return pad+v.v4+v.v5+v.v7;
    case 11:return pad+v.v4+v.v5+v.v6;
    case 12:case"★":return Math.max(pad+v.v4+v.v5+v.v6,pad+v.v4+v.v5+v.v7)+v.v8;
    default:return 0;
  }
}
function toggleV(){const b=document.getElementById("vbody"),a=document.getElementById("varr");if(b.style.display==="none"){b.style.display="";a.style.transform="";}else{b.style.display="none";a.style.transform="rotate(-90deg)";}}
function herbereken(){
  const route=document.getElementById("route").value;
  const variant=document.getElementById("variant").value;
  const gsuVal=document.getElementById("gsu").value;
  const sleutel=route+"_"+variant;
  let gsuDatum=null;
  if(gsuVal){const[y,m,d]=gsuVal.split("-").map(Number);gsuDatum=new Date(y,m-1,d);gsuDatum.setHours(0,0,0,0);}
  const v=vv();
  const ti=xw("★",sleutel,v);
  const balk=document.getElementById("impact-balk");
  if(ti===0){balk.className="impact-balk impact-ok";balk.innerHTML="✅ Geen vertraging ingevoerd — planning haalbaar";}
  else{balk.className="impact-balk impact-warn";balk.innerHTML=`⚠️ Totale vertraging op GSU: <strong>+${ti} week${ti!==1?"en":""}</strong> — GSU moet eerder gepland worden of het project verschuift`;}
  const vs=fmt(new Date());
  document.getElementById("vandaag-txt").textContent="Vandaag: "+vs;
  document.getElementById("footer-datum").textContent=vs;
  const tbody=document.getElementById("tbl-body");
  tbody.innerHTML="";
  let hf="";
  M.forEach(m=>{
    const bw=m.wk[sleutel];
    const nvt=bw===null;
    const ex=nvt?0:xw(m.nr,sleutel,v);
    const cw=nvt?null:bw+ex;
    let datum=null;
    if(gsuDatum&&cw!==null)datum=telDagen(gsuDatum,cw);
    const sv=staat[m.nr]||"";
    const s=nvt?{icon:"⏸",label:"n.v.t.",kl:"d-nvt"}:(!gsuDatum?{icon:"—",label:"vul GSU in",kl:"d-leeg"}:sl(datum,sv));
    const isG=m.nr==="★";
    if(m.fase!==hf){hf=m.fase;const sep=document.createElement("tr");sep.className="divider-row";sep.innerHTML=`<td colspan="10">${m.fase}</td>`;tbody.appendChild(sep);}
    const tr=document.createElement("tr");
    if(isG)tr.className="gsu-row";
    const dt=nvt?"n.v.t.":(!gsuDatum?"→ vul GSU in":(fmt(datum)||"—"));
    const et=nvt?"—":(ex>0?`<span class="wk-extra-pos">+${ex}</span>`:"0");
    tr.innerHTML=`
      <td class="nr-cel ${isG?"nr-gsu":""}">${m.nr}</td>
      <td><span class="fase-badge ${fKl(m.fase)}">${m.fase}</span></td>
      <td><div class="mijl-titel">${m.titel} ${tHtml(m)}</div><div class="mijl-sub">${m.sub}</div></td>
      <td class="wie-cel">${m.wie}</td>
      <td class="wk-cel">${nvt?"—":bw+" wk"}</td>
      <td class="wk-cel">${et}</td>
      <td class="wk-cel" style="font-weight:600;">${nvt?"—":cw+" wk"}</td>
      <td><div class="datum-cel ${s.kl}">${dt}</div>${s.label?`<div style="font-size:10px;color:#aaa;margin-top:2px;">${s.label}</div>`:""}</td>
      <td class="sl-cel"><span class="sl-icon">${s.icon}</span><select class="status-sel" data-nr="${m.nr}" onchange="sw(this)">${SO.map(o=>`<option value="${o.v}"${o.v===sv?" selected":""}>${o.l}</option>`).join("")}</select></td>
      <td class="toel">${m.toel}</td>`;
    tbody.appendChild(tr);
  });
}
function sw(sel){staat[sel.dataset.nr]=sel.value;herbereken();}
document.addEventListener("DOMContentLoaded",()=>{
  const d=new Date();d.setMonth(d.getMonth()+6);
  document.getElementById("gsu").value=d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");
  herbereken();
});
</script>
</body>
